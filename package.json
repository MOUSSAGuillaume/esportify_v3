  },
  "homepage": "https://github.com/MOUSSAGuillaume/esportify_v3#readme",
  "dependencies": {
    "bootstrap": "^5.3.8"
  },
  "devDependencies": {
    "sass": "^1.97.3",
    "shx": "^0.4.0"
  }

{
  "name": "esportify_v3",
  "version": "1.0.0",
  "description": "Esportify v3 — Backend (PHP + MySQL + MongoDB)",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:css": "sass frontend/assets/scss/app.scss frontend/assets/css/app.css --watch",
    "build:css": "sass frontend/assets/scss/app.scss frontend/assets/css/app.css --style=compressed",
    "vendor:bootstrap": "shx mkdir -p frontend/assets/vendor/bootstrap/css frontend/assets/vendor/bootstrap/js && shx cp node_modules/bootstrap/dist/css/bootstrap.min.css frontend/assets/vendor/bootstrap/css/bootstrap.min.css && shx cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js frontend/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MOUSSAGuillaume/esportify_v3.git"
  },
